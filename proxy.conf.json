{
  "/api/*": {
    "target": "http://localhost:5006",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug"
  },
  "/mcp/*": {
    "target": "http://localhost:5006",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug"
  },
  "/jarvis/ws/stream": {
    "target": "http://localhost:12012/ws/stream",
    "secure": false,
    "ws": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/jarvis": ""
    },
    "logLevel": "debug"
  },
  "/jarvis/api/*": {
    "target": "http://localhost:12012/api",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/jarvis": ""
    },
    "logLevel": "debug"
  }
}